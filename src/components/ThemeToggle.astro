<div class="theme-toggle-wrapper">
  <button
    class="theme-toggle"
    id="themeToggle"
    type="button"
    aria-label="Toggle dark mode"
    title="Toggle dark mode"
  >
    <!-- Auto icon (system) -->
    <svg class="icon icon-auto" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="3" width="20" height="14" rx="2" />
      <line x1="8" y1="21" x2="16" y2="21" />
      <line x1="12" y1="17" x2="12" y2="21" />
    </svg>
    <!-- Sun icon -->
    <svg class="icon icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5" />
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </svg>
    <!-- Moon icon -->
    <svg class="icon icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </button>
</div>

<style>
  .theme-toggle-wrapper {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 100;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: all var(--transition);
    color: var(--color-text-muted);
  }

  .theme-toggle:hover {
    background: var(--color-btn-hover);
    color: var(--color-text);
    transform: scale(1.05);
  }

  .icon {
    position: absolute;
    transition: opacity var(--transition), transform var(--transition);
  }

  /* Default: all hidden */
  .icon-auto,
  .icon-sun,
  .icon-moon {
    opacity: 0;
    transform: scale(0.6);
  }

  /* Auto: show monitor icon */
  :global(html[data-theme="auto"]) .icon-auto {
    opacity: 1;
    transform: scale(1);
  }

  /* Light: show sun icon */
  :global(html[data-theme="light"]) .icon-sun {
    opacity: 1;
    transform: scale(1);
  }

  /* Dark: show moon icon */
  :global(html[data-theme="dark"]) .icon-moon {
    opacity: 1;
    transform: scale(1);
  }
</style>

<script>
  const btn = document.getElementById("themeToggle") as HTMLButtonElement;
  if (!btn) throw new Error("Theme toggle button not found");

  // Three states: auto → dark → light → auto
  function getNextTheme(): string | null {
    const stored = localStorage.getItem("theme");
    if (!stored) return "dark";
    if (stored === "dark") return "light";
    return null; // null = auto (remove from storage)
  }

  function applyTheme(theme: string | null) {
    if (theme === "dark" || theme === "light") {
      localStorage.setItem("theme", theme);
      document.documentElement.classList.toggle("dark", theme === "dark");
      document.documentElement.dataset.theme = theme;
    } else {
      localStorage.removeItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.classList.toggle("dark", prefersDark);
      document.documentElement.dataset.theme = "auto";
    }
  }

  // Set initial data-theme on load
  (function init() {
    const stored = localStorage.getItem("theme");
    if (stored === "dark" || stored === "light") {
      document.documentElement.dataset.theme = stored;
    } else {
      document.documentElement.dataset.theme = "auto";
    }
  })();

  btn.addEventListener("click", () => {
    const next = getNextTheme();
    applyTheme(next);
  });
</script>
