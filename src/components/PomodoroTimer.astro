---
export interface Props {
  minutes?: number;
  seconds?: number;
  totalSeconds?: number;
  isRunning?: boolean;
  sessionType?: "focus" | "short-break" | "long-break";
}
---

<div class="timer-container">
  <svg class="timer-ring" viewBox="0 0 200 200" aria-hidden="true">
    <circle class="ring-bg" cx="100" cy="100" r="88" />
    <circle
      class="ring-progress"
      cx="100"
      cy="100"
      r="88"
      data-total-seconds="1500"
      data-remaining-seconds="1500"
    />
  </svg>
  <div class="timer-display" id="timerDisplay">
    <!-- Read-only spans -->
    <span class="timer-readonly" id="timerReadonly">
      <span class="timer-minutes" id="timerMinutes">25</span>
      <span class="timer-colon">:</span>
      <span class="timer-seconds" id="timerSeconds">00</span>
    </span>
    <!-- Editable inputs (hidden by default) -->
    <span class="timer-edit" id="timerEdit" style="display:none">
      <input
        class="timer-input"
        id="inputMinutes"
        type="text"
        inputmode="numeric"
        maxlength="3"
        value="25"
        autocomplete="off"
      />
      <span class="timer-colon-edit">:</span>
      <input
        class="timer-input"
        id="inputSeconds"
        type="text"
        inputmode="numeric"
        maxlength="2"
        value="00"
        autocomplete="off"
      />
    </span>
  </div>
</div>

<div class="session-controls">
  <button class="session-btn active" data-type="focus" data-duration="1500">
    Focus
  </button>
  <button class="session-btn" data-type="short-break" data-duration="300">
    Short Break
  </button>
  <button class="session-btn" data-type="long-break" data-duration="900">
    Long Break
  </button>
  <button class="session-btn" data-type="custom" data-duration="0">
    Custom
  </button>
</div>

<div class="button-row">
  <button class="main-btn" id="mainBtn" aria-label="Start timer">
    <svg class="play-icon" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
      <polygon points="5,3 19,12 5,21" />
    </svg>
    <svg class="pause-icon" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" style="display:none">
      <rect x="6" y="4" width="4" height="16" rx="1" />
      <rect x="14" y="4" width="4" height="16" rx="1" />
    </svg>
  </button>

  <button class="reset-btn" id="resetBtn" aria-label="Reset timer">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="1 4 1 10 7 10" />
      <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />
    </svg>
  </button>
</div>

<style>
  .timer-container {
    position: relative;
    width: 260px;
    height: 260px;
    margin: 0 auto 2rem;
  }

  .timer-ring {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .ring-bg {
    fill: none;
    stroke: var(--color-ring-bg);
    stroke-width: 6;
  }

  .ring-progress {
    fill: none;
    stroke: var(--color-ring-active);
    stroke-width: 6;
    stroke-linecap: round;
    stroke-dasharray: 552.92;
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.3s linear, stroke var(--transition);
  }

  .timer-display {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
    cursor: pointer;
  }

  .timer-readonly,
  .timer-edit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
  }

  .timer-minutes,
  .timer-seconds {
    font-size: 4.5rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .timer-colon {
    font-size: 4rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-top: -4px;
  }

  /* Editable inputs */
  .timer-input {
    font-family: inherit;
    font-size: 4.5rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    color: var(--color-text);
    background: transparent;
    border: none;
    outline: none;
    text-align: center;
    width: 3ch;
    padding: 0;
    caret-color: var(--color-accent);
    border-radius: 4px;
    transition: background var(--transition);
  }

  .timer-input:focus {
    background: var(--color-btn-hover);
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  #inputMinutes {
    width: 3.5ch;
  }

  #inputSeconds {
    width: 2.5ch;
  }

  .timer-colon-edit {
    font-size: 4rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-top: -4px;
    pointer-events: none;
  }

  /* Session Controls */
  .session-controls {
    display: flex;
    gap: 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.375rem;
    box-shadow: var(--shadow-sm);
    margin-bottom: 2rem;
  }

  .session-btn {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: all var(--transition);
    white-space: nowrap;
  }

  .session-btn:hover {
    color: var(--color-text);
    background: var(--color-btn-hover);
  }

  .session-btn.active {
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 2px 8px rgba(231, 76, 60, 0.35);
  }

  .session-btn[data-type="short-break"].active {
    background: var(--color-accent-short-break);
    box-shadow: 0 2px 8px rgba(34, 197, 94, 0.35);
  }

  .session-btn[data-type="long-break"].active {
    background: var(--color-accent-long-break);
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.35);
  }

  /* Button Row */
  .button-row {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  /* Main Button */
  .main-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 6px 20px rgba(231, 76, 60, 0.4);
    transition: all var(--transition);
  }

  .main-btn:hover {
    transform: scale(1.07);
    box-shadow: 0 8px 28px rgba(231, 76, 60, 0.5);
  }

  .main-btn:active {
    transform: scale(0.97);
  }

  /* Reset Button */
  .reset-btn {
    position: absolute;
    left: calc(50% + 52px);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: all var(--transition);
    opacity: 0;
    pointer-events: none;
    transform: scale(0.85);
  }

  .reset-btn.visible {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }

  .reset-btn:hover {
    color: var(--color-text);
    background: var(--color-btn-hover);
  }

  /* Running state */
  .timer-container.running .timer-minutes,
  .timer-container.running .timer-seconds {
    animation: pulse-text 2s ease-in-out infinite;
  }

  /* Hide cursor when running */
  .timer-container.running .timer-display {
    cursor: default;
  }

  @keyframes pulse-text {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.85; }
  }
</style>

<script>
  // ── State ──
  const CIRCUMFERENCE = 2 * Math.PI * 88; // ~552.92

  const ringProgress = document.querySelector(".ring-progress") as SVGCircleElement;
  const minutesEl = document.getElementById("timerMinutes") as HTMLSpanElement;
  const secondsEl = document.getElementById("timerSeconds") as HTMLSpanElement;
  const timerReadonly = document.getElementById("timerReadonly") as HTMLSpanElement;
  const timerEdit = document.getElementById("timerEdit") as HTMLSpanElement;
  const inputMinutes = document.getElementById("inputMinutes") as HTMLInputElement;
  const inputSeconds = document.getElementById("inputSeconds") as HTMLInputElement;
  const timerDisplay = document.getElementById("timerDisplay") as HTMLDivElement;
  const mainBtn = document.getElementById("mainBtn") as HTMLButtonElement;
  const resetBtn = document.getElementById("resetBtn") as HTMLButtonElement;
  const playIcon = mainBtn.querySelector(".play-icon") as SVGElement;
  const pauseIcon = mainBtn.querySelector(".pause-icon") as SVGElement;
  const sessionBtns = document.querySelectorAll<HTMLButtonElement>(".session-btn");
  const timerContainer = document.querySelector(".timer-container") as HTMLDivElement;

  let totalSeconds = 1500; // 25 min default
  let remainingSeconds = 1500;
  let isRunning = false;
  let intervalId: ReturnType<typeof setInterval> | null = null;
  let currentSessionType = "focus";

  function updateResetVisibility() {
    resetBtn.classList.toggle("visible", remainingSeconds !== totalSeconds);
  }

  function updateDisplay() {
    const m = Math.floor(remainingSeconds / 60);
    const s = remainingSeconds % 60;
    minutesEl.textContent = String(m).padStart(2, "0");
    secondsEl.textContent = String(s).padStart(2, "0");

    const offset = CIRCUMFERENCE * (1 - remainingSeconds / totalSeconds);
    ringProgress.style.strokeDashoffset = String(offset);
    ringProgress.setAttribute("data-remaining-seconds", String(remainingSeconds));
    updateResetVisibility();
  }

  function updateRingColor() {
    if (currentSessionType === "short-break") {
      ringProgress.style.stroke = "var(--color-ring-active-short-break)";
    } else if (currentSessionType === "long-break") {
      ringProgress.style.stroke = "var(--color-ring-active-long-break)";
    } else {
      ringProgress.style.stroke = "var(--color-ring-active)";
    }
  }

  function stopTimer() {
    if (intervalId) {
      clearInterval(intervalId);
      intervalId = null;
    }
    isRunning = false;
    timerContainer.classList.remove("running");
    playIcon.style.display = "block";
    pauseIcon.style.display = "none";
    mainBtn.setAttribute("aria-label", "Start timer");
  }

  function playSound() {
    const ctx = new AudioContext();
    const now = ctx.currentTime;

    // Pleasant three-note chime: C5 → E5 → G5
    const notes = [523.25, 659.25, 783.99];
    notes.forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = "sine";
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.3, now + i * 0.15);
      gain.gain.exponentialRampToValueAtTime(0.001, now + i * 0.15 + 0.4);
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.start(now + i * 0.15);
      osc.stop(now + i * 0.15 + 0.4);
    });
  }

  function startTimer() {
    if (remainingSeconds <= 0) return;
    exitEditMode();
    isRunning = true;
    timerContainer.classList.add("running");
    playIcon.style.display = "none";
    pauseIcon.style.display = "block";
    mainBtn.setAttribute("aria-label", "Pause timer");

    intervalId = setInterval(() => {
      remainingSeconds -= 1;
      updateDisplay();

      if (remainingSeconds <= 0) {
        stopTimer();
        playSound();
        ringProgress.style.strokeDashoffset = String(CIRCUMFERENCE);
        // Brief flash
        timerContainer.style.filter = "brightness(1.1)";
        setTimeout(() => {
          timerContainer.style.filter = "";
        }, 300);
      }
    }, 1000);
  }

  function resetTimer() {
    stopTimer();
    remainingSeconds = totalSeconds;
    updateDisplay();
    ringProgress.style.strokeDashoffset = "0";
  }

  // ── Edit mode (custom time input) ──
  let isEditing = false;

  function enterEditMode() {
    if (isRunning) return;
    isEditing = true;
    timerReadonly.style.display = "none";
    timerEdit.style.display = "";
    const m = Math.floor(remainingSeconds / 60);
    const s = remainingSeconds % 60;
    inputMinutes.value = String(m).padStart(2, "0");
    inputSeconds.value = String(s).padStart(2, "0");
    inputMinutes.focus();
    inputMinutes.select();
    setSessionTab("custom");
  }

  function exitEditMode() {
    if (!isEditing) return;
    isEditing = false;
    parseAndApplyCustomTime();
    timerReadonly.style.display = "";
    timerEdit.style.display = "none";
    updateDisplay();
  }

  function parseAndApplyCustomTime() {
    let mins = parseInt(inputMinutes.value, 10) || 0;
    let secs = parseInt(inputSeconds.value, 10) || 0;

    // Clamp
    mins = Math.max(0, Math.min(999, mins));
    secs = Math.max(0, Math.min(59, secs));

    const total = mins * 60 + secs;
    if (total > 0) {
      totalSeconds = total;
      remainingSeconds = total;
      ringProgress.style.strokeDashoffset = "0";
    }
  }

  function setSessionTab(type: string) {
    currentSessionType = type;
    updateRingColor();
    sessionBtns.forEach((btn) => {
      btn.classList.toggle("active", btn.dataset.type === type);
    });
  }

  // ── Input handling ──
  inputMinutes.addEventListener("input", () => {
    let val = inputMinutes.value.replace(/\D/g, "");
    if (val.length > 3) val = val.slice(0, 3);
    inputMinutes.value = val;
    // Auto-advance to seconds after 3 digits
    if (val.length === 3) {
      inputSeconds.focus();
      inputSeconds.select();
    }
  });

  inputMinutes.addEventListener("keydown", (e) => {
    if (e.key === ":" || e.key === "ArrowRight") {
      e.preventDefault();
      inputSeconds.focus();
      inputSeconds.select();
      return;
    }
    if (e.key === "Enter") {
      e.preventDefault();
      exitEditMode();
      return;
    }
    if (e.key === "ArrowUp") {
      e.preventDefault();
      let val = parseInt(inputMinutes.value, 10) || 0;
      val = Math.min(999, val + 1);
      inputMinutes.value = String(val).padStart(2, "0");
      return;
    }
    if (e.key === "ArrowDown") {
      e.preventDefault();
      let val = parseInt(inputMinutes.value, 10) || 0;
      val = Math.max(0, val - 1);
      inputMinutes.value = String(val).padStart(2, "0");
      return;
    }
  });

  inputSeconds.addEventListener("input", () => {
    let val = inputSeconds.value.replace(/\D/g, "");
    if (val.length > 2) val = val.slice(0, 2);
    inputSeconds.value = val;
  });

  inputSeconds.addEventListener("keydown", (e) => {
    if (e.key === "ArrowLeft" && inputSeconds.selectionStart === 0) {
      e.preventDefault();
      inputMinutes.focus();
      return;
    }
    if (e.key === "Enter") {
      e.preventDefault();
      exitEditMode();
      return;
    }
    if (e.key === "ArrowUp") {
      e.preventDefault();
      let mins = parseInt(inputMinutes.value, 10) || 0;
      let secs = parseInt(inputSeconds.value, 10) || 0;
      if (secs >= 59) {
        secs = 0;
        mins = Math.min(999, mins + 1);
      } else {
        secs += 1;
      }
      inputMinutes.value = String(mins).padStart(2, "0");
      inputSeconds.value = String(secs).padStart(2, "0");
      return;
    }
    if (e.key === "ArrowDown") {
      e.preventDefault();
      let mins = parseInt(inputMinutes.value, 10) || 0;
      let secs = parseInt(inputSeconds.value, 10) || 0;
      if (secs <= 0) {
        secs = 59;
        mins = Math.max(0, mins - 1);
      } else {
        secs -= 1;
      }
      inputMinutes.value = String(mins).padStart(2, "0");
      inputSeconds.value = String(secs).padStart(2, "0");
      return;
    }
  });

  // Commit on blur
  inputMinutes.addEventListener("blur", () => {
    // Small delay so a click on another input registers first
    setTimeout(() => {
      if (document.activeElement !== inputSeconds) {
        exitEditMode();
      }
    }, 100);
  });

  inputSeconds.addEventListener("blur", () => {
    setTimeout(() => {
      if (document.activeElement !== inputMinutes) {
        exitEditMode();
      }
    }, 100);
  });

  // ── Click timer display to edit when stopped ──
  timerDisplay.addEventListener("click", (e) => {
    if (isRunning) return;
    if (isEditing) return;
    // Don't trigger if clicking on an input
    if (e.target === inputMinutes || e.target === inputSeconds) return;
    enterEditMode();
  });

  // ── Session buttons ──
  function setSession(type: string, duration: number) {
    stopTimer();
    exitEditMode();
    setSessionTab(type);
    if (type === "custom") {
      // Keep current time for custom, enter edit mode
      enterEditMode();
    } else {
      totalSeconds = duration;
      remainingSeconds = duration;
      updateDisplay();
      ringProgress.style.strokeDashoffset = "0";
    }
  }

  // ── Event Listeners ──
  mainBtn.addEventListener("click", () => {
    if (isRunning) {
      stopTimer();
    } else {
      exitEditMode();
      startTimer();
    }
  });

  resetBtn.addEventListener("click", resetTimer);

  sessionBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const type = btn.dataset.type!;
      const duration = parseInt(btn.dataset.duration!, 10);
      setSession(type, duration);
    });
  });

  // Initial render
  updateDisplay();
</script>
